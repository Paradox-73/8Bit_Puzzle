{
  "uid": "8bit-overview",
  "title": "8Bit Overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP requests / sec (by service)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Process CPU usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
