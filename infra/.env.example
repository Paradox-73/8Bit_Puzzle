# Copy to infra/.env (gitignored) and fill in for a real deployment.
# Docker Compose reads infra/.env automatically. Leave blank for local dev.

# Stable JWT signing key (>= 32 bytes). Blank => app mints an ephemeral key (dev only).
JWT_SECRET=

# --- Managed databases (for the JVM-only cloud deploy: docker-compose.cloud.yml) ---
# Neon Postgres: copy the JDBC URL (KEEP ?sslmode=require), user and password from the Neon dashboard.
DB_URL=
DB_USER=
DB_PASSWORD=
# Upstash Redis: host + port + password from the Upstash dashboard. TLS is required.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=true

# Comma-separated allowed CORS origins, or * (Bearer-token auth, so no cookie/CSRF risk).
CORS_ORIGINS=*

# Your backend's public domain (Caddy gets free HTTPS for it). Use a free DuckDNS subdomain, e.g.
# bitpuzzle.duckdns.org — point it at the VM's static IP. Required by docker-compose.cloud.yml.
SITE_DOMAIN=

# Set to false in production to skip seeding demo data entirely.
SEED_ENABLED=true

# Admin master login code. Login is passwordless (email + OTP); admins/editors may type THIS secret
# code in place of the emailed OTP, so an admin is never locked out by email. Keep it secret and
# strong. Blank => admins must use the normal emailed code like everyone else.
ADMIN_LOGIN_CODE=

# Email OTP delivery. Without MAIL_HOST, codes are written to the backend log (fine for dev).
OTP_FROM=8bit@iiitb.ac.in
# Restrict sign-ups to a domain (default iiitb.ac.in). Set empty to allow any email domain.
OTP_EMAIL_DOMAIN=iiitb.ac.in
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Where player feedback / bug reports are emailed. Defaults to the team address if unset.
FEEDBACK_TO=8bit@iiitb.ac.in

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
