# Copy to infra/.env (gitignored) and fill in for a real deployment.
# Docker Compose reads infra/.env automatically. Leave blank for local dev.

# Stable JWT signing key (>= 32 bytes). Blank => app mints an ephemeral key (dev only).
JWT_SECRET=

# Database password for a real/managed Postgres. Blank works with the local trust-auth DB.
DB_PASSWORD=

# Comma-separated allowed CORS origins, or * (Bearer-token auth, so no cookie/CSRF risk).
CORS_ORIGINS=*

# Editor seed password. Blank => a random one is generated and printed to the logs on first boot.
SEED_EDITOR_PASSWORD=
# Set to false in production to skip seeding demo data entirely.
SEED_ENABLED=true

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
